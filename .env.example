# Required for OpenRouter cloud models (optional if using only local providers)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: LM Studio API token (if authentication is enabled in LM Studio)
# LM_API_TOKEN=

# Optional: web pre-search before council (Serper — https://serper.dev, 2500 free searches/month)
# You can also set this in the app under Settings → Web search instead of here.
SERPER_API_KEY=
WEB_SEARCH_PROVIDER=serper

# Optional: NVIDIA NIM cloud models (https://build.nvidia.com/models)
# You can also set this in the app under Settings → NVIDIA NIM instead of here.
NVIDIA_API_KEY=
